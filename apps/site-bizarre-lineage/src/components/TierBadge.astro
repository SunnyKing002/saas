---
// src/components/TierBadge.astro
interface Props {
  tier: "S+" | "S" | "A" | "B";
  size?: "sm" | "md" | "lg";
}

const { tier, size = "md" } = Astro.props;

// 高质量霓虹发光色系
const tierColors = {
  "S+": { text: "#ef4444", bg: "rgba(239, 68, 68, 0.12)", border: "rgba(239, 68, 68, 0.3)", glow: "rgba(239, 68, 68, 0.4)" },
  "S": { text: "#f59e0b", bg: "rgba(245, 158, 11, 0.12)", border: "rgba(245, 158, 11, 0.3)", glow: "rgba(245, 158, 11, 0.4)" },
  "A": { text: "#a855f7", bg: "rgba(168, 85, 247, 0.12)", border: "rgba(168, 85, 247, 0.3)", glow: "rgba(168, 85, 247, 0.4)" },
  "B": { text: "#3b82f6", bg: "rgba(59, 130, 246, 0.12)", border: "rgba(59, 130, 246, 0.3)", glow: "rgba(59, 130, 246, 0.4)" },
};

const styles = tierColors[tier];
---
<span 
  class={`tier-badge size-${size}`} 
  style={`
    color: ${styles.text}; 
    background: ${styles.bg}; 
    border-color: ${styles.border};
    text-shadow: 0 0 10px ${styles.glow};
    box-shadow: inset 0 0 8px ${styles.bg}, 0 0 12px ${styles.bg};
  `}
>
  {tier}
</span>

<style>
  .tier-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-weight: 800;
  }

  .size-sm {
    min-width: 32px;
    height: 24px;
    font-size: 0.75rem;
    border-radius: 6px;
  }

  .size-md {
    min-width: 44px;
    height: 32px;
    font-size: 1.1rem;
    border-radius: 8px;
  }

  .size-lg {
    min-width: 60px;
    height: 48px;
    font-size: 1.6rem;
    border-radius: 12px;
  }
</style>
