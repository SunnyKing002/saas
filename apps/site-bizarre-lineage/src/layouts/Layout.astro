---
// src/layouts/Layout.astro
import Navbar from "../components/Navbar.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../../site.config";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  exactTitle?: boolean;
}

const {
  title = "Bizarre Lineage Wiki & Tools",
  description = "The ultimate wiki and tools for Roblox Bizarre Lineage. Find tier lists, Stand guides, builds, and codes.",
  canonicalPath = "",
  exactTitle = false,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, Astro.site || siteConfig.domain);
const pageTitle = exactTitle ? title : `${title} | ${siteConfig.title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <!-- Ads & Analytics (Lazy Loaded to eliminate TBT) -->
    <script is:inline>
      let scriptsLoaded = false;
      const loadThirdParty = () => {
        if (scriptsLoaded) return;
        scriptsLoaded = true;

        // 1. Google Analytics
        const ga = document.createElement('script');
        ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-JGRS5V8H3V';
        ga.async = true;
        document.body.appendChild(ga);
        window.dataLayer = window.dataLayer || [];
        window.gtag = function(){dataLayer.push(arguments);}
        window.gtag('js', new Date());
        window.gtag('config', 'G-JGRS5V8H3V');

        // 2. Google AdSense
        const adsense = document.createElement('script');
        adsense.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5724967585602439';
        adsense.crossOrigin = 'anonymous';
        adsense.async = true;
        document.body.appendChild(adsense);

        // 3. Monetag Vignette
        const monetag1 = document.createElement('script');
        monetag1.src = 'https://gizokraijaw.net/vignette.min.js';
        monetag1.dataset.zone = '10706691';
        document.body.appendChild(monetag1);

        // 4. Monetag Tag
        const monetag2 = document.createElement('script');
        monetag2.src = 'https://5gvci.com/act/files/tag.min.js?z=10706888';
        monetag2.dataset.cfasync = 'false';
        monetag2.async = true;
        document.body.appendChild(monetag2);
      };

      // Load on first interaction (improves mobile PageSpeed Insights drastically)
      const interactEvents = ['scroll', 'mousemove', 'touchstart', 'click'];
      interactEvents.forEach(e => window.addEventListener(e, loadThirdParty, { once: true, passive: true }));
      // Fallback: load automatically after 3.5s to ensure impressions if user is idle
      setTimeout(loadThirdParty, 3500);
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo.png" />
    <meta property="og:site_name" content={siteConfig.title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/logo.png" />

    <!-- JSON-LD WebSite and Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": siteConfig.title,
        "url": siteConfig.domain,
        "description": "The ultimate wiki and tools for Roblox Bizarre Lineage. Tier lists, stand guides, codes, and builds.",
        "potentialAction": {
          "@type": "SearchAction",
          "target": siteConfig.domain + "/stands/{search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": siteConfig.title,
        "url": siteConfig.domain,
        "logo": new URL("/logo.png", Astro.site || siteConfig.domain).toString()
      }
    ])} />
    
    <!-- Font Preconnections for FCP optimization -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    
    <!-- FCP/LCP Optimization: Reduced font weights explicitly to only what is needed -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;800;900&display=swap" media="print" onload="this.media='all'">
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;800;900&display=swap">
    </noscript>
    <!-- Sidebar State check to prevent FOUC -->
    <script is:inline>
      const sidebarState = localStorage.getItem('bizarre-lineage-sidebar');
      if (sidebarState === 'collapsed') {
        document.documentElement.classList.add('sidebar-collapsed');
      } else {
        document.documentElement.classList.add('sidebar-expanded');
      }
    </script>
  </head>
  <body>
    <!-- Ambient Background Glows -->
    <div class="ambient-glow glow-top-left"></div>
    <div class="ambient-glow glow-bottom-right"></div>
    
    <Navbar />
    <Sidebar />
    <main class="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* 
   * Bizarre Lineage Premium Theme 
   * Dark Space Purple / Cyber Gold
   */
  :root {
    /* Core Colors */
    --color-bg-base: #0a0512;        /* Very dark purple/black */
    --color-bg-surface: #130a24;     /* Raised surface */
    --color-bg-elevated: #1a0f35;    /* Popovers, cards */
    
    /* Accents (Purple & Gold/Amber) */
    --color-primary: #8b5cf6;        /* Vibrant purple */
    --color-primary-glow: rgba(139, 92, 246, 0.4);
    --color-accent: #f59e0b;         /* Stand Arrow Gold */
    --color-accent-glow: rgba(245, 158, 11, 0.3);
    
    /* Text */
    --color-text-primary: #f8fafc;
    --color-text-secondary: #cbd5e1;
    --color-text-muted: #64748b;
    
    /* Borders & Glass */
    --color-border: rgba(139, 92, 246, 0.15);
    --color-glass-bg: rgba(19, 10, 36, 0.6);
    --color-glass-border: rgba(255, 255, 255, 0.05);

    /* Typography */
    --font-heading: 'Outfit', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  /* INP Optimization: Eradicate mobile touch delays & layout tap-highlights */
  html {
    font-family: var(--font-body);
    background-color: var(--color-bg-base);
    color: var(--color-text-primary);
    scroll-behavior: smooth;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  /* INP / Mobile UX: Enforce 44px minimum touch targets */
  a, button, [role="button"] {
    min-height: 44px;
    min-width: 44px;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow-x: clip;
  }

  /* Headings Typography */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-top: 0;
  }

  p {
    line-height: 1.6;
  }

  /* Ambient Glow Effects for Background */
  .ambient-glow {
    position: fixed;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    z-index: -1;
    opacity: 0.5;
    pointer-events: none;
  }
  
  .glow-top-left {
    top: -200px;
    left: -200px;
    background: radial-gradient(circle, rgba(139,92,246,0.2) 0%, transparent 70%);
  }

  .glow-bottom-right {
    bottom: -200px;
    right: -200px;
    background: radial-gradient(circle, rgba(245,158,11,0.1) 0%, transparent 70%);
  }

  .main-content {
    flex: 1;
    min-height: calc(100vh - 140px); /* rough navbar + footer height */
    padding-bottom: 4rem;
  }

  /* Structural Classes */
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section {
    padding: 4rem 0;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #f8fafc 0%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  /* Base Animations */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
</style>
