---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Privacy Policy" description="Privacy policy for Bizarre Lineage Wiki." canonicalPath="/privacy">
  <section class="section"><div class="container page-content">
    <h1>Privacy Policy</h1>
    <p><em>Last updated: March 2026</em></p>
    <h2>Information We Collect</h2>
    <p>This site does not require user registration. We may collect anonymous usage data through analytics services to improve the site experience.</p>
    <h2>Cookies</h2>
    <p>We may use cookies for analytics purposes. You can disable cookies in your browser settings.</p>
    <h2>Third-Party Services</h2>
    <p>We may use Google Analytics or similar services to understand site traffic. These services may collect anonymized data about your visit.</p>
    <h2>Children's Privacy</h2>
    <p>This site does not knowingly collect personal information from children under 13 years of age.</p>
    <h2>Contact</h2>
    <p>For privacy concerns, contact us at <strong>privacy@bizarre-lineage.com</strong>.</p>
  </div></section>
</Layout>
<style>
  .page-content { max-width: 680px; }
  h1 { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 0 0 1rem; }
  h2 { font-size: 1.1rem; font-weight: 700; color: #e2e8f0; margin: 2rem 0 0.5rem; }
  p { color: #94a3b8; font-size: 0.9rem; line-height: 1.7; }
  p strong, p em { color: #e2e8f0; }
</style>
