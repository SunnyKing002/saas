---
import Layout from "../layouts/Layout.astro";
import StandCard from "../components/StandCard.astro";
import FAQ from "../components/FAQ.astro";
import { stands } from "../data/stands";
import { Trophy, Gift, Swords, BookOpen, ArrowRight } from "lucide-react";

// Fetch Top Stands (S+ and S)
const topStands = stands
  .filter((s) => s.tier === "S+" || s.tier === "S")
  .slice(0, 4);

const faqs = [
  {
    question: "What is Bizarre Lineage on Roblox?",
    answer: "Bizarre Lineage is a popular Roblox experience inspired by JoJo's Bizarre Adventure. Players collect and fight with Stands, equip fighting styles, and unlock sub-abilities to dominate PvP arenas and PvE quests. Our Bizarre Lineage wiki covers every mechanic in detail."
  },
  {
    question: "When do new Bizarre Lineage codes drop?",
    answer: "Developers typically release new Bizarre Lineage codes during major holidays, player milestones like 50k concurrent users, or large content updates. Bookmark our Bizarre Lineage codes page — we update it within minutes of every new drop."
  },
  {
    question: "Which Bizarre Lineage Stand is best for leveling from 1-50?",
    answer: "For fastest PvE leveling in Bizarre Lineage, choose a Stand with large AoE damage such as Whitesnake or Magician's Red. Pair them with Boxing or Vampire for maximum sustain. See our Bizarre Lineage leveling guide for the complete route."
  },
  {
    question: "How do I awaken my Stand in Bizarre Lineage?",
    answer: "To awaken a Stand in Bizarre Lineage, reach max Level 50, obtain a Requiem Arrow from boss drops or redeem codes, and complete the final story quest. Our Bizarre Lineage awakening guide has step-by-step boss strategies."
  },
  {
    question: "How many Stands are in Bizarre Lineage?",
    answer: "There are currently 17 unique Stands in Bizarre Lineage, ranging from Common rarity to Mythical. Each Stand has its own moveset, passive ability, and recommended fighting style pairing. Browse every Stand in our Bizarre Lineage stands database."
  }
];


---

<Layout
  title="Bizarre Lineage Wiki — Tier List, Codes & Stands Guide (2026)"
  description="Bizarre Lineage hub for Roblox players. Get the latest tier list, active codes, all 17 stands, fighting styles, and leveling guides — updated daily."
>
  <!-- HERO SECTION -->
  <section class="hero-section">
    <div class="container hero-content animate-fade-in">
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        Updated March 2026
      </div>
      
      <h1 class="hero-title">
        Bizarre Lineage
        <span class="gradient-text">Complete Wiki, Tier List & Codes</span>
      </h1>
      
      <p class="hero-desc">
        Your one-stop Bizarre Lineage resource for Roblox. Discover the highest-ranked Stands, claim every active redeem code, explore optimal build combos, and master leveling routes — all verified by experienced players and updated daily.
      </p>
      
      <div class="hero-cta">
        <a href="/tier-list" class="btn btn-primary btn-glow">View Bizarre Lineage Tier List</a>
        <a href="/codes" class="btn btn-secondary glass-btn">Check Bizarre Lineage Codes</a>
      </div>
      
      <!-- Hero Stats Bar -->
      <div class="hero-stats">
        <div class="stat-box">
          <span class="stat-number">17</span>
          <span class="stat-label">Stands Scanned</span>
        </div>
        <div class="divider"></div>
        <div class="stat-box">
          <span class="stat-number">4</span>
          <span class="stat-label">Sub-Abilities</span>
        </div>
        <div class="divider"></div>
        <div class="stat-box">
          <span class="stat-number text-accent">S+</span>
          <span class="stat-label">Current Meta</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY USE THIS BIZARRE LINEAGE WIKI -->
  <section class="intro-section section">
    <div class="container intro-content">
      <h2 class="section-title">Why Use This Bizarre Lineage Wiki?</h2>
      <p class="section-subtitle">
        Most Bizarre Lineage guides online are buried in ads, outdated, or incomplete. We built this Bizarre Lineage wiki differently — every data point comes straight from in-game testing, every tier list ranking is backed by leaderboard statistics, and every page loads instantly with zero bloat.
      </p>
      <p class="intro-body">
        Whether you just started playing Bizarre Lineage or you are grinding for your third <a href="/bizarre-lineage-prestige">bizarre lineage prestige</a>, this hub gives you the competitive edge. Browse our <a href="/stands">Bizarre Lineage stands database</a> for raw stats, check the <a href="/tier-list">Bizarre Lineage tier list</a> to pick the strongest Stand for your playstyle, and never miss a free reward with our <a href="/codes">Bizarre Lineage codes</a> tracker.
      </p>
    </div>
  </section>

  <!-- FEATURES BENTO GRID -->
  <section class="features-section section">
    <div class="container">
      <h2 class="section-title">Explore Bizarre Lineage Tools & Guides</h2>
      <div class="bento-grid">
        <a href="/tier-list" class="bento-card bento-large glass-card align-bottom">
          <div class="bento-watermark">
            <Trophy size={120} />
          </div>
          <div class="bento-inner">
            <Trophy size={40} className="bento-icon text-accent" />
            <div class="bento-badges">
              <span class="badge badge-s">S+ Tier</span>
              <span class="badge badge-meta">Meta</span>
            </div>
            <h3>Bizarre Lineage Tier List</h3>
            <p>Current meta rankings for PvP and PvE. All 17 Stands graded from S+ to B by top-ranked players. See who dominates the leaderboard this patch.</p>
          </div>
        </a>
        <a href="/codes" class="bento-card glass-card">
          <Gift size={40} className="bento-icon text-accent" />
          <h3>Bizarre Lineage Codes</h3>
          <p>Free Stand Arrows, Rokakaka Fruits, Cash, and EXP Boosts. Updated within minutes of every drop.</p>
        </a>
        <a href="/stands" class="bento-card glass-card">
          <Swords size={40} className="bento-icon text-purple" />
          <h3>Bizarre Lineage Stands</h3>
          <p>Browse all 17 Stands with raw stats, passives, movesets, and best fighting style pairings.</p>
        </a>
        <a href="/guides/leveling" class="bento-card bento-wide glass-card">
          <div class="bento-wide-content">
            <BookOpen size={40} className="bento-icon" />
            <div>
              <h3>Bizarre Lineage Guides</h3>
              <p>Optimal leveling routes from 1-50, <a href="/bizarre-lineage-prestige">bizarre lineage prestige</a> requirements, awakening walkthroughs, and stat allocation tips.</p>
            </div>
          </div>
          <div class="arrow-right"><ArrowRight size={24} /></div>
        </a>
      </div>
    </div>
  </section>

  <!-- TOP STANDS SECTION -->
  <section class="top-stands-section section">
    <div class="container">
      <h2 class="section-title">Top Bizarre Lineage Stands This Meta</h2>
      <p class="section-subtitle">
        The dominant picks controlling the current Bizarre Lineage PvP ladder.
        These Stands deliver overwhelming damage, crowd control, and mobility.
      </p>
      
      <div class="stands-grid">
        {topStands.map((stand) => (
          <StandCard stand={stand} />
        ))}
      </div>
      <div class="view-all-stands">
        <a href="/stands" class="link-with-arrow">View All Bizarre Lineage Stands <span>→</span></a>
      </div>
    </div>
  </section>

  <!-- FEATURED VIDEO SECTION -->
  <section class="featured-video-section section">
    <div class="container">
      <h2 class="section-title">Watch Bizarre Lineage in Action</h2>
      <p class="section-subtitle">Check out the latest gameplay showcases, combo guides, and new Stand previews from the community.</p>
      
      <div class="video-container glass-card">
        <iframe 
          width="100%" 
          height="100%" 
          src="https://www.youtube.com/embed/Tx0h0rJK6yo" 
          title="Bizarre Lineage Gameplay Showcase" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section class="faq-section section">
    <div class="container">
      <h2 class="section-title">Bizarre Lineage FAQ</h2>
      <p class="section-subtitle">Common questions from the Bizarre Lineage community — answered by experienced players.</p>
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta section">
    <div class="container" style="text-align:center;">
      <h2 class="section-title">Ready to Dominate Bizarre Lineage?</h2>
      <p class="section-subtitle">Pick your Stand, optimize your build, and start climbing the leaderboard today.</p>
      <div class="hero-cta" style="justify-content:center;">
        <a href="/tier-list" class="btn btn-primary btn-glow">Browse Bizarre Lineage Tier List</a>
        <a href="/guides/leveling" class="btn btn-secondary glass-btn">Read Bizarre Lineage Leveling Guide</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* Hero Section */
.hero-section {
  padding: 8rem 0 4rem;
  text-align: center;
  position: relative;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 800px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 1rem;
  border-radius: 99px;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.3);
  color: var(--color-primary);
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 2rem;
  box-shadow: 0 0 20px rgba(139, 92, 246, 0.1);
}

.pulse-dot {
  width: 8px;
  height: 8px;
  background-color: var(--color-primary);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--color-primary);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.7); }
  70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(139, 92, 246, 0); }
  100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(139, 92, 246, 0); }
}

.hero-title {
  font-size: 4.5rem;
  line-height: 1.1;
  font-weight: 900;
  margin-bottom: 1.5rem;
  color: #fff;
}

.gradient-text {
  display: block;
  background: linear-gradient(135deg, var(--color-primary), #fbbf24);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 16px rgba(139,92,246,0.3));
  font-size: 0.65em;
}

.hero-desc {
  font-size: 1.15rem;
  color: var(--color-text-secondary);
  max-width: 650px;
  margin-bottom: 3rem;
  line-height: 1.7;
}

.hero-cta {
  display: flex;
  gap: 1rem;
  margin-bottom: 4rem;
  flex-wrap: wrap;
}

.btn {
  padding: 1rem 2rem;
  border-radius: 99px;
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.btn-primary {
  background: var(--color-text-primary);
  color: #000;
}

.btn-primary:hover {
  transform: translateY(-2px) scale(1.05);
  box-shadow: 0 8px 25px rgba(255,255,255,0.2)
}

.glass-btn {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--color-text-primary);
}

.glass-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  transform: translateY(-2px);
  border-color: rgba(255, 255, 255, 0.2);
}

/* Hero Stats */
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  padding: 1.5rem 3rem;
  background: var(--color-glass-bg);
  border: 1px solid var(--color-glass-border);
  border-radius: 20px;
  backdrop-filter: blur(20px);
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
}

.stat-number {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 800;
  color: var(--color-text-primary);
}

.text-accent { color: var(--color-accent); text-shadow: 0 0 10px var(--color-accent-glow); }
.text-purple { color: var(--color-primary); }

.stat-label {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 600;
}

.divider {
  width: 1px;
  height: 40px;
  background: rgba(255, 255, 255, 0.1);
}

/* Intro Section */
.intro-content {
  max-width: 800px;
  text-align: center;
}

.intro-body {
  color: var(--color-text-secondary);
  font-size: 1rem;
  line-height: 1.7;
  max-width: 700px;
  margin: 0 auto;
}

.intro-body a {
  color: var(--color-primary);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.intro-body a:hover {
  color: var(--color-text-primary);
}

/* Bento Grid */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: minmax(140px, auto);
  gap: 1.5rem;
}

.glass-card {
  background: var(--color-glass-bg);
  border: 1px solid var(--color-glass-border);
  border-radius: 24px;
  padding: 2rem;
  text-decoration: none;
  transition: all 0.3s ease;
  overflow: hidden;
  position: relative;
}

.glass-card:hover {
  transform: translateY(-4px);
  background: rgba(26, 15, 53, 0.8);
  border-color: rgba(139, 92, 246, 0.3);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 30px rgba(139, 92, 246, 0.1);
}

.bento-large {
  grid-column: span 2;
  grid-row: span 2;
  background-image: radial-gradient(circle at bottom right, rgba(245, 158, 11, 0.1), transparent 50%);
}

.align-bottom {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.bento-watermark {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  opacity: 0.15;
  pointer-events: none;
  transition: opacity 0.3s;
}

.bento-large:hover .bento-watermark {
  opacity: 0.3;
}

.bento-inner {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 85%;
}

.bento-wide {
  grid-column: span 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bento-wide-content {
  display: flex;
  align-items: flex-start;
  gap: 1.5rem;
}

.bento-icon {
  margin-bottom: 1rem;
}

.bento-card h3 {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 0.6rem;
  letter-spacing: -0.02em;
}

.bento-card p {
  color: var(--color-text-secondary);
  font-size: 1rem;
  margin: 0;
  line-height: 1.6;
}

.bento-badges {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 0.8rem;
}

.badge {
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.2rem 0.6rem;
  border-radius: 6px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.badge-s {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1px solid rgba(239, 68, 68, 0.3);
}

.badge-meta {
  background: rgba(139, 92, 246, 0.15);
  color: var(--color-primary);
  border: 1px solid rgba(139, 92, 246, 0.3);
}

.arrow-right {
  font-size: 1.5rem;
  color: var(--color-primary);
  opacity: 0.5;
  transition: all 0.3s;
}

.bento-wide:hover .arrow-right {
  opacity: 1;
  transform: translateX(4px);
}

.text-purple { color: var(--color-primary); }
.text-accent { color: var(--color-accent); }

/* Stands Grid */
.stands-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-bottom: 3rem;
  margin-top: 2rem;
  text-align: left;
}

.link-with-arrow {
  color: var(--color-text-secondary);
  font-family: var(--font-heading);
  font-weight: 500;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: color 0.2s;
}

.link-with-arrow span {
  transition: transform 0.2s;
  color: var(--color-primary);
}

.link-with-arrow:hover {
  color: var(--color-text-primary);
}

.link-with-arrow:hover span {
  transform: translateX(4px);
}

.view-all-stands {
  text-align: center;
}

/* Video Embed */
.video-container {
  aspect-ratio: 16 / 9;
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  padding: 0;
  overflow: hidden;
  border-radius: 20px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 30px rgba(139, 92, 246, 0.15);
}

.video-container iframe {
  width: 100%;
  height: 100%;
  border: none;
}

/* Responsive */
@media (max-width: 1024px) {
  .bento-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .hero-title { font-size: 3rem; }
  .hero-stats {
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    width: 100%;
  }
  .divider { width: 100%; height: 1px; }
  .bento-grid { grid-template-columns: 1fr; }
  .bento-large, .bento-wide { grid-column: span 1; }
  .bento-wide-content { flex-direction: column; gap: 0.5rem; }
}
</style>
