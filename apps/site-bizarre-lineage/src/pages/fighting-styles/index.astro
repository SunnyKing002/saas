---
// src/pages/fighting-styles/index.astro
import Layout from "../../layouts/Layout.astro";
import { fightingStyles } from "../../data/fighting-styles";
import { getStandBySlug } from "../../data/stands";
import { Swords, Info, Zap, Shield, ArrowRight, Crosshair, HelpCircle, ChevronRight } from "lucide-react";

const seoTitle = "Bizarre Lineage Fighting Styles | Ranked Guide & Best Pairings | Bizarre Lineage";
const seoDesc = "Master the meta with our complete guide to Bizarre Lineage Fighting Styles. Discover the best builds, combo potential, and Stand pairings. Read the ultimate 2026 guide now.";

// SEO FAQ Schema specifically tuned for the fighting styles keyword
const faqs = [
  {
    question: "What are the best Bizarre Lineage Fighting Styles for PvP?",
    answer: "The best Bizarre Lineage Fighting Styles depend heavily on your active Stand. Generally, Boxing is considered the top tier for close-range combat and endless combo extensions, while Vampirism is heavily favored by defensive players looking for ultimate sustain in drawn-out PvP encounters."
  },
  {
    question: "Can I have multiple Bizarre Lineage Fighting Styles at once?",
    answer: "No, players can only equip one of the Bizarre Lineage Fighting Styles at a time. If you wish to learn a new discipline like Kendo or Vampirism, you must speak to the respective trainer and pay the required currency, which will overwrite your current style."
  },
  {
    question: "Do Bizarre Lineage Fighting Styles increase raw damage?",
    answer: "Absolutely. Bizarre Lineage Fighting Styles provide passive damage scaling and active abilities that deal significant burst damage. Styles like Boxing have a very high damage scaling stat (8/10), meaning your basic M1 attacks will slice through enemy health much faster compared to having no style equipped."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<Layout
  title={seoTitle}
  description={seoDesc}
  canonicalPath="/fighting-styles"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <header class="styles-hero">
    <div class="hero-glow"></div>
    <div class="container relative z-10 text-center">
      <span class="hero-kicker">Ultimate 2026 Meta Guide</span>
      <h1 class="hero-h1">Bizarre Lineage Fighting Styles: <br/>The Ultimate Combat Guide</h1>
      <p class="hero-sub">
        Unlock your true combat potential by mastering the core <strong>Bizarre Lineage Fighting Styles</strong>. Whether you prefer the relentless combo chains of Boxing, the mid-range counter-attacks of Kendo, or the life-stealing sustain of Vampirism, choosing the right fighting style is the critical difference between dominating the PvP arena and losing your hard-earned streak.
      </p>
      <div class="hero-actions">
        <a href="#ranked-list" class="hero-cta">Explore All Styles</a>
      </div>
    </div>
  </header>

  <div class="container page-body">

    <!-- Why Section -->
    <section class="mb-16">
      <h2 class="h2-title">Why You Need to Master Bizarre Lineage Fighting Styles</h2>
      <div class="glass-panel p-content">
        <p class="body-text mb-6">
          In the competitive landscape of this Roblox universe, relying solely on your Stand abilities is a massive beginner's mistake. <strong>Bizarre Lineage Fighting Styles</strong> act as a critical secondary moveset that completely alters your approach to engagement and survival. These specialized combat disciplines grant you brand new active abilities, fundamentally alter your M1 (basic attack) combo strings, and provide entirely new defensive or offensive tactical advantages. 
        </p>
        <p class="body-text mb-8">
          When ranking the very best <strong>Bizarre Lineage Fighting Styles</strong>, top-tier professional players evaluate three primary factors: raw combo extension potential, base damage scaling multipliers, and direct synergy with S-Tier Stands. For example, a burst-heavy Stand like The World requires a specific fighting style that allows for devastating, uninterrupted burst windows during a Time Stop. If you ignore optimizing your fighting style, you are essentially fighting with one arm tied behind your back.
        </p>
        <div class="three-boxes">
          <div class="info-box">
            <Zap className="box-icon text-accent" />
            <h4>Combo Extensions</h4>
            <p>Fighting styles break the M1 barrier, allowing infinite loops.</p>
          </div>
          <div class="info-box">
            <Shield className="box-icon text-green" />
            <h4>Stat Amplification</h4>
            <p>Boost your base damage, mobility, and passive health sustain.</p>
          </div>
          <div class="info-box">
            <Crosshair className="box-icon text-blue" />
            <h4>Stand Synergy</h4>
            <p>Cover your Stand's weak points (e.g., adding range to a melee Stand).</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Main List Section -->
    <section id="ranked-list" class="mb-16">
      <h2 class="h2-title">Top Ranked Bizarre Lineage Fighting Styles List</h2>
      <p class="section-desc">Below is the complete database of every currently available <strong>Bizarre Lineage Fighting Styles</strong> in the 2026 meta. Review their pros, cons, and best Stand pairings carefully before committing your in-game currency.</p>
      
      <div class="styles-stack">
        {fightingStyles.map((style) => (
          <article class="style-article glass-panel" id={`style-${style.slug}`}>
            
            {/* Left Content */}
            <div class="style-left">
              <div class="style-title-row">
                <div class="style-icon-wrapper">
                  <Swords size={24} />
                </div>
                <h3 class="style-h3">{style.name} — Bizarre Lineage Fighting Styles</h3>
              </div>
              
              <p class="body-text mb-6">{style.description}</p>
              
              <div class="stat-grid">
                <div class="stat-cell">
                  <span class="stat-label">Combo Potential</span>
                  <span class="stat-val text-accent">{style.comboPoential}/10</span>
                </div>
                <div class="stat-cell">
                  <span class="stat-label">Damage Scaling</span>
                  <span class="stat-val text-red">{style.damageScaling}/10</span>
                </div>
                <div class="stat-cell">
                  <span class="stat-label">Combat Range</span>
                  <span class="stat-val text-blue">{style.range}</span>
                </div>
              </div>

              <div class="moves-section">
                <h4 class="small-heading">Unique Ability Moveset</h4>
                <div class="move-list">
                  {style.moves.map(move => (
                    <div class="move-item">
                      <span class="move-key">{move.key}</span>
                      <div>
                        <strong class="move-name">{move.name}</strong>
                        <p class="move-desc">{move.description}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div class="obtain-box">
                <h4 class="small-heading flex-center gap-2"><Info size={16} /> How to Obtain</h4>
                <p class="obtain-text">{style.howToGet}</p>
              </div>
            </div>

            {/* Right Sidebar */}
            <div class="style-right">
              <h4 class="small-heading text-center">Pros & Cons Analysis</h4>
              
              <div class="pros-block">
                <strong class="pros-label">Advantages (Pros)</strong>
                <ul class="pros-list">
                  {style.pros.map(pro => <li><span>+</span> {pro}</li>)}
                </ul>
              </div>
              
              <div class="cons-block">
                <strong class="cons-label">Vulnerabilities (Cons)</strong>
                <ul class="cons-list">
                  {style.cons.map(con => <li><span>-</span> {con}</li>)}
                </ul>
              </div>

              <h4 class="small-heading text-center top-border">Best Stand Pairings</h4>
              <div class="pairings-grid">
                {style.bestStands.map(slug => {
                  const s = getStandBySlug(slug);
                  return s ? (
                    <a href={`/stands/${s.slug}`} class="pairing-chip">{s.name}</a>
                  ) : null;
                })}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Two Col Section -->
    <div class="two-col-grid mb-16">
      
      <!-- Steps -->
      <section class="glass-panel p-content">
        <h2 class="h2-small">Step-by-Step: How to Get Bizarre Lineage Fighting Styles</h2>
        <p class="body-text mb-6">Follow these exact instructions within the game map to secure your combat discipline without wasting time running around randomly.</p>
        
        <div class="steps-list">
          <div class="step">
            <div class="step-num">1</div>
            <div>
              <strong>Gather In-Game Currency</strong>
              <p class="step-text">All Bizarre Lineage Fighting Styles cost between $5,000 to $10,000. Defeat thugs or complete storyline quests to farm this cash quickly.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div>
              <strong>Locate the Specific Trainer NPC</strong>
              <p class="step-text">Reference the exact bus stop locations mentioned in the cards above. The Boxing trainer is at the Gym, Kendo at the Dojo.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div>
              <strong>Equip and Train</strong>
              <p class="step-text">Once purchased, the new style is immediately bound to your character. Press your designated ability keys to unleash your new moves in the wild.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="glass-panel p-content">
        <h2 class="h2-small flex-center gap-2">
          <HelpCircle className="text-accent" size={22} /> Bizarre Lineage Fighting Styles FAQ
        </h2>
        <div class="faq-list">
          {faqs.map(faq => (
            <details class="faq-item">
              <summary class="faq-q">
                {faq.question}
                <ChevronRight className="faq-icon" size={18} />
              </summary>
              <p class="faq-a">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>
    </div>

    <!-- CTA Section -->
    <section class="cta-section">
      <h2 class="cta-title">Ready to Dominate with Top Bizarre Lineage Fighting Styles?</h2>
      <p class="cta-body">
        Now that you understand the intricacies of every combat discipline, it's time to pair them with the ultimate Stand. Check out our comprehensive tier list to find the perfect synergistic match for your newly acquired skills.
      </p>
      <a href="/tier-list" class="btn-primary">
        View Global Tier List <ArrowRight size={20} />
      </a>
    </section>

  </div>
</Layout>

<style>
  /* Base & Utility */
  .page-body { max-width: 1100px; margin: 0 auto; padding: 0 1rem; }
  .glass-panel {
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 20px;
  }
  .p-content { padding: 2rem; }
  .mb-6 { margin-bottom: 1.5rem; }
  .mb-8 { margin-bottom: 2rem; }
  .mb-16 { margin-bottom: 4rem; }
  .text-accent { color: var(--color-accent); }
  .text-green { color: #4ade80; }
  .text-blue { color: #60a5fa; }
  .text-red { color: #f87171; }
  .flex-center { display: flex; align-items: center; }
  .gap-2 { gap: 0.5rem; }
  
  /* Hero */
  .styles-hero {
    position: relative;
    padding: 6rem 0 4rem;
    border-bottom: 1px solid var(--color-glass-border);
    overflow: hidden;
    text-align: center;
    margin-bottom: 3rem;
  }
  .hero-glow {
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 800px; height: 100%;
    background: radial-gradient(ellipse at top, rgba(168,85,247,0.15) 0%, transparent 70%);
    z-index: 0; pointer-events: none;
  }
  .hero-kicker {
    display: block; font-size: 0.85rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.15em; color: var(--color-accent); margin-bottom: 1rem;
  }
  .hero-h1 {
    font-size: clamp(2rem, 5vw, 3.8rem); font-weight: 900; color: #fff;
    line-height: 1.15; margin: 0 auto 1.5rem; max-width: 900px;
  }
  .hero-sub {
    font-size: 1.15rem; color: var(--color-text-secondary); max-width: 800px;
    margin: 0 auto 2rem; line-height: 1.7;
  }
  .hero-sub strong { color: #fff; }
  .hero-actions { display: flex; justify-content: center; gap: 1rem; }
  .hero-cta {
    display: inline-block; background: var(--color-primary); color: #fff;
    font-weight: 800; padding: 1rem 2.5rem; border-radius: 99px; text-decoration: none;
    transition: all 0.2s; box-shadow: 0 0 24px rgba(168,85,247,0.4);
  }
  .hero-cta:hover { transform: scale(1.05); background: #a855f7; }

  /* Typography */
  .h2-title {
    font-size: 1.8rem; font-weight: 800; color: #fff; margin: 0 0 1rem;
    padding-bottom: 0.75rem; border-bottom: 1px solid var(--color-glass-border);
  }
  .h2-small { font-size: 1.4rem; font-weight: 700; color: #fff; margin: 0 0 1.2rem; }
  .small-heading {
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--color-text-muted); margin: 0 0 0.8rem;
  }
  .small-heading.top-border { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.2rem; margin-top: 1.5rem; }
  .section-desc { color: var(--color-text-secondary); margin-bottom: 2rem; max-width: 800px; line-height: 1.6; }
  .body-text { color: var(--color-text-secondary); line-height: 1.7; font-size: 1.05rem; }
  .body-text strong { color: #fff; }

  /* Why Section Boxes */
  .three-boxes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; }
  .info-box {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px; padding: 1.5rem; text-align: center; transition: border-color 0.2s;
  }
  .info-box:hover { border-color: rgba(168,85,247,0.4); }
  .box-icon { width: 40px; height: 40px; margin: 0 auto 1rem; }
  .info-box h4 { color: #fff; font-weight: 700; margin: 0 0 0.5rem; font-size: 1rem; }
  .info-box p { color: var(--color-text-muted); font-size: 0.85rem; margin: 0; line-height: 1.4; }

  /* Styles List */
  .styles-stack { display: flex; flex-direction: column; gap: 2.5rem; }
  .style-article {
    display: grid; grid-template-columns: 1fr 340px;
    overflow: hidden; transition: border-color 0.3s;
  }
  .style-article:hover { border-color: rgba(168,85,247,0.4); }
  .style-left { padding: 2rem; border-right: 1px solid var(--color-glass-border); }
  .style-right { padding: 2rem; background: rgba(0,0,0,0.2); }

  .style-title-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  .style-icon-wrapper {
    width: 48px; height: 48px; border-radius: 12px;
    background: rgba(168,85,247,0.2); border: 1px solid rgba(168,85,247,0.3);
    display: flex; align-items: center; justify-content: center; color: var(--color-accent);
  }
  .style-h3 { font-size: 1.5rem; font-weight: 900; color: #fff; margin: 0; letter-spacing: -0.02em; }

  .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
  .stat-cell { background: rgba(0,0,0,0.3); border-radius: 12px; padding: 1rem; text-align: center; }
  .stat-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 0.3rem; }
  .stat-val { font-size: 1.5rem; font-weight: 900; }

  .moves-section { margin-bottom: 2rem; }
  .move-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .move-item { display: flex; align-items: flex-start; gap: 0.75rem; background: rgba(255,255,255,0.04); padding: 0.75rem 1rem; border-radius: 10px; }
  .move-key {
    background: rgba(168,85,247,0.2); color: var(--color-accent);
    border: 1px solid rgba(168,85,247,0.3); border-radius: 6px;
    min-width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 0.85rem; flex-shrink: 0;
  }
  .move-name { display: block; font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 0.25rem; }
  .move-desc { font-size: 0.8rem; color: var(--color-text-muted); margin: 0; line-height: 1.4; }

  .obtain-box {
    margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.05);
  }
  .obtain-text { font-size: 0.85rem; color: #fef08a; background: rgba(234,179,8,0.1); border: 1px solid rgba(234,179,8,0.2); padding: 0.8rem 1rem; border-radius: 10px; margin: 0; }

  .pros-block, .cons-block { margin-bottom: 1.5rem; }
  .pros-label { display: block; font-size: 0.85rem; font-weight: 700; color: #4ade80; margin-bottom: 0.6rem; }
  .cons-label { display: block; font-size: 0.85rem; font-weight: 700; color: #f87171; margin-bottom: 0.6rem; }
  .cons-block { background: rgba(248,113,113,0.05); border: 1px solid rgba(248,113,113,0.1); padding: 1rem; border-radius: 12px; }
  
  .pros-list, .cons-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .pros-list li { font-size: 0.85rem; color: var(--color-text-secondary); display: flex; gap: 0.5rem; align-items: flex-start; }
  .cons-list li { font-size: 0.85rem; color: var(--color-text-secondary); display: flex; gap: 0.5rem; align-items: flex-start; }
  .pros-list span { color: #4ade80; font-weight: 900; }
  .cons-list span { color: #f87171; font-weight: 900; }

  .pairings-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
  .pairing-chip {
    font-size: 0.75rem; font-weight: 700; color: #fff;
    background: rgba(168,85,247,0.2); border: 1px solid rgba(168,85,247,0.3);
    padding: 0.35rem 0.8rem; border-radius: 99px; text-decoration: none;
    transition: all 0.2s;
  }
  .pairing-chip:hover { background: var(--color-primary); }

  /* Two Col section */
  .two-col-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  
  /* Steps */
  .steps-list { display: flex; flex-direction: column; gap: 1rem; }
  .step { display: flex; gap: 1rem; align-items: flex-start; }
  .step-num {
    width: 32px; height: 32px; border-radius: 50%; background: var(--color-primary);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; color: #fff; font-size: 0.9rem; flex-shrink: 0;
  }
  .step strong { display: block; font-size: 0.95rem; color: #fff; margin-bottom: 0.25rem; }
  .step-text { font-size: 0.85rem; color: var(--color-text-secondary); margin: 0; line-height: 1.5; }

  /* FAQ */
  .faq-list { display: flex; flex-direction: column; gap: 1rem; }
  .faq-item {
    background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px; overflow: hidden;
  }
  .faq-q {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 1.25rem; cursor: pointer; font-weight: 700;
    color: #fff; font-size: 0.95rem; list-style: none; transition: background 0.2s;
  }
  .faq-q:hover { background: rgba(255,255,255,0.05); }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-icon { color: var(--color-text-muted); flex-shrink: 0; transition: transform 0.2s; }
  details[open] .faq-icon { transform: rotate(90deg); }
  .faq-a { font-size: 0.85rem; color: var(--color-text-secondary); padding: 0 1.25rem 1rem; margin: 0; line-height: 1.6; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem; }

  /* CTA */
  .cta-section {
    text-align: center; padding: 4rem 2rem; margin-bottom: 5rem;
    background: radial-gradient(ellipse at center, rgba(168,85,247,0.1) 0%, transparent 100%);
    border: 1px solid rgba(255,255,255,0.05); border-radius: 24px;
  }
  .cta-title { font-size: 2rem; font-weight: 900; color: #fff; margin: 0 0 1rem; }
  .cta-body { color: var(--color-text-secondary); max-width: 700px; margin: 0 auto 2rem; font-size: 1.1rem; line-height: 1.6; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #fff; color: #000; font-weight: 900; padding: 1rem 2.5rem;
    border-radius: 99px; text-decoration: none; transition: all 0.2s;
    box-shadow: 0 0 20px rgba(255,255,255,0.2);
  }
  .btn-primary:hover { background: #e9d5ff; transform: scale(1.05); }

  /* Responsive */
  @media (max-width: 900px) {
    .style-article { grid-template-columns: 1fr; }
    .style-left { border-right: none; border-bottom: 1px solid var(--color-glass-border); }
    .two-col-grid { grid-template-columns: 1fr; }
    .three-boxes { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .stat-grid { grid-template-columns: 1fr; }
  }
</style>
