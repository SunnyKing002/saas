---
// src/pages/fighting-styles/index.astro
import Layout from "../../layouts/Layout.astro";
import { fightingStyles } from "../../data/fighting-styles";
import { getStandBySlug } from "../../data/stands";
import { Swords, Info, Zap, Shield, ArrowRight, Crosshair, HelpCircle, ChevronRight } from "lucide-react";

const seoTitle = "Bizarre Lineage Fighting Styles | Ranked Guide & Best Pairings | Bizarre Lineage";
const seoDesc = "Master the meta with our complete guide to Bizarre Lineage Fighting Styles. Discover the best builds, combo potential, and Stand pairings. Read the ultimate 2026 guide now.";

// SEO FAQ Schema specifically tuned for the fighting styles keyword
const faqs = [
  {
    question: "What are the best Bizarre Lineage Fighting Styles for PvP?",
    answer: "The best Bizarre Lineage Fighting Styles depend heavily on your active Stand. Generally, Boxing is considered the top tier for close-range combat and endless combo extensions, while Vampirism is heavily favored by defensive players looking for ultimate sustain in drawn-out PvP encounters."
  },
  {
    question: "Can I have multiple Bizarre Lineage Fighting Styles at once?",
    answer: "No, players can only equip one of the Bizarre Lineage Fighting Styles at a time. If you wish to learn a new discipline like Kendo or Vampirism, you must speak to the respective trainer and pay the required currency, which will overwrite your current style."
  },
  {
    question: "Do Bizarre Lineage Fighting Styles increase raw damage?",
    answer: "Absolutely. Bizarre Lineage Fighting Styles provide passive damage scaling and active abilities that deal significant burst damage. Styles like Boxing have a very high damage scaling stat (8/10), meaning your basic M1 attacks will slice through enemy health much faster compared to having no style equipped."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<Layout
  title={seoTitle}
  description={seoDesc}
  canonicalPath="/fighting-styles"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- SEO Highly Optimized Hero Section -->
  <header class="styles-hero relative py-24 mb-12 border-b border-white/10 overflow-hidden">
    <div class="header-glow absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-full bg-[radial-gradient(ellipse_at_top,rgba(168,85,247,0.15)_0%,transparent_70%)] z-0 pointer-events-none"></div>
    <div class="container relative z-10 text-center max-w-4xl mx-auto">
      <span class="text-accent text-sm font-bold tracking-[0.15em] uppercase mb-4 block">Ultimate 2026 Meta Guide</span>
      <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">Bizarre Lineage Fighting Styles: <br/>The Ultimate Combat Guide</h1>
      <p class="text-lg md:text-xl text-gray-300 leading-relaxed max-w-3xl mx-auto mb-8">
        Unlock your true combat potential by mastering the core <strong class="text-white">Bizarre Lineage Fighting Styles</strong>. Whether you prefer the relentless combo chains of Boxing, the mid-range counter-attacks of Kendo, or the life-stealing sustain of Vampirism, choosing the right fighting style is the critical difference between dominating the PvP arena and losing your hard-earned streak.
      </p>
      <div class="flex justify-center gap-4">
        <a href="#ranked-list" class="bg-primary hover:bg-purple-500 text-white font-bold py-4 px-8 rounded-full transition-all hover:scale-105 shadow-[0_0_20px_rgba(168,85,247,0.4)]">
          Explore All Styles
        </a>
      </div>
    </div>
  </header>

  <div class="container max-w-6xl mx-auto px-4">
    
    <!-- SEO Narrative Section 1 -->
    <section class="mb-16 animate-fade-in">
      <h2 class="text-3xl font-bold text-white mb-6 border-b border-white/10 pb-4">Why You Need to Master Bizarre Lineage Fighting Styles</h2>
      <div class="glass-panel p-8">
        <p class="text-gray-300 mb-6 leading-relaxed text-lg">
          In the competitive landscape of this Roblox universe, relying solely on your Stand abilities is a massive beginner's mistake. <strong class="text-white">Bizarre Lineage Fighting Styles</strong> act as a critical secondary moveset that completely alters your approach to engagement and survival. These specialized combat disciplines grant you brand new active abilities, fundamentally alter your M1 (basic attack) combo strings, and provide entirely new defensive or offensive tactical advantages. 
        </p>
        <p class="text-gray-300 leading-relaxed text-lg mb-6">
          When ranking the very best <strong class="text-white">Bizarre Lineage Fighting Styles</strong>, top-tier professional players evaluate three primary factors: raw combo extension potential, base damage scaling multipliers, and direct synergy with S-Tier Stands. For example, a burst-heavy Stand like The World requires a specific fighting style that allows for devastating, uninterrupted burst windows during a Time Stop. If you ignore optimizing your fighting style, you are essentially fighting with one arm tied behind your back.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
          <div class="bg-white/5 border border-white/10 rounded-xl p-6 text-center hover:border-primary/50 transition-colors">
            <Zap className="w-10 h-10 text-accent mx-auto mb-4" />
            <h4 class="text-white font-bold mb-2">Combo Extensions</h4>
            <p class="text-sm text-gray-400">Fighting styles break the M1 barrier, allowing infinite loops.</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-6 text-center hover:border-primary/50 transition-colors">
            <Shield className="w-10 h-10 text-green-400 mx-auto mb-4" />
            <h4 class="text-white font-bold mb-2">Stat Amplification</h4>
            <p class="text-sm text-gray-400">Boost your base damage, mobility, and passive health sustain.</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-6 text-center hover:border-primary/50 transition-colors">
            <Crosshair className="w-10 h-10 text-blue-400 mx-auto mb-4" />
            <h4 class="text-white font-bold mb-2">Stand Synergy</h4>
            <p class="text-sm text-gray-400">Cover your Stand's weak points (e.g., adding range to a melee Stand).</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Main List Section -->
    <section id="ranked-list" class="mb-16">
      <h2 class="text-3xl font-bold text-white mb-2">Top Ranked Bizarre Lineage Fighting Styles List</h2>
      <p class="text-gray-400 mb-8 max-w-3xl">Below is the complete database of every currently available <strong class="text-gray-300">Bizarre Lineage Fighting Styles</strong> in the 2026 meta. Review their pros, cons, and best Stand pairings carefully before committing your in-game currency.</p>
      
      <div class="space-y-10">
        {fightingStyles.map((style) => (
          <article class="glass-panel overflow-hidden border border-white/10 hover:border-primary/40 transition-all flex flex-col lg:flex-row group" id={`style-${style.slug}`}>
            
            {/* Left Content */}
            <div class="p-8 lg:w-[65%] border-b lg:border-b-0 lg:border-r border-white/10 flex flex-col justify-between">
              <div>
                <div class="flex items-center gap-4 mb-4">
                  <div class="w-12 h-12 rounded-xl bg-primary/20 border border-primary/30 flex items-center justify-center text-primary">
                    <Swords size={24} />
                  </div>
                  <h3 class="text-2xl font-black text-white tracking-tight m-0">{style.name} — Bizarre Lineage Fighting Styles</h3>
                </div>
                
                <p class="text-gray-300 leading-relaxed mb-6 text-base md:text-lg">{style.description}</p>
                
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-8">
                  <div class="bg-black/30 p-4 rounded-xl text-center">
                    <span class="block text-xs uppercase font-bold text-gray-500 mb-1">Combo Potential</span>
                    <span class="text-2xl font-black text-accent">{style.comboPoential}/10</span>
                  </div>
                  <div class="bg-black/30 p-4 rounded-xl text-center">
                    <span class="block text-xs uppercase font-bold text-gray-500 mb-1">Damage Scaling</span>
                    <span class="text-2xl font-black text-red-400">{style.damageScaling}/10</span>
                  </div>
                  <div class="bg-black/30 p-4 rounded-xl text-center col-span-2 md:col-span-1">
                    <span class="block text-xs uppercase font-bold text-gray-500 mb-1">Combat Range</span>
                    <span class="text-2xl font-black text-blue-400">{style.range}</span>
                  </div>
                </div>

                <div class="mb-6">
                  <h4 class="text-sm font-bold uppercase text-gray-400 mb-3 tracking-wider">Unique Ability Moveset</h4>
                  <div class="space-y-3">
                    {style.moves.map(move => (
                      <div class="flex gap-3 items-start bg-white/5 p-3 rounded-lg">
                        <span class="bg-primary/20 text-primary font-black border border-primary/30 rounded px-2 py-1 min-w-[32px] text-center text-sm">{move.key}</span>
                        <div>
                          <strong class="text-white text-sm block mb-1">{move.name}</strong>
                          <p class="text-xs text-gray-400 m-0 leading-snug">{move.description}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <div class="mt-6 pt-6 border-t border-white/5">
                <h4 class="text-sm font-bold uppercase text-gray-400 mb-3 tracking-wider flex items-center gap-2">
                  <Info size={16} /> How to Obtain
                </h4>
                <p class="text-sm text-gray-300 m-0 bg-yellow-500/10 border border-yellow-500/20 px-4 py-3 rounded-lg text-yellow-100/80">
                  {style.howToGet}
                </p>
              </div>
            </div>

            {/* Right Sidebar */}
            <div class="p-8 lg:w-[35%] bg-black/20 flex flex-col justify-between">
              <div>
                <h4 class="text-sm font-bold uppercase text-gray-400 mb-4 tracking-wider text-center">Pros & Cons Analysis</h4>
                
                <div class="mb-6">
                  <strong class="text-green-400 text-sm block mb-2 px-2">Advantages (Pros)</strong>
                  <ul class="space-y-2">
                    {style.pros.map(pro => (
                      <li class="flex items-start gap-2 text-sm text-gray-300">
                        <span class="text-green-400 font-bold mt-0.5">+</span> {pro}
                      </li>
                    ))}
                  </ul>
                </div>
                
                <div class="mb-8 p-4 bg-red-500/5 rounded-xl border border-red-500/10">
                  <strong class="text-red-400 text-sm block mb-2">Vulnerabilities (Cons)</strong>
                  <ul class="space-y-2">
                    {style.cons.map(con => (
                      <li class="flex items-start gap-2 text-sm text-gray-300">
                        <span class="text-red-400 font-bold mt-0.5">-</span> {con}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <div>
                <h4 class="text-sm font-bold uppercase text-gray-400 mb-3 tracking-wider text-center border-t border-white/10 pt-6">Best Stand Pairings</h4>
                <div class="flex flex-wrap gap-2 justify-center">
                  {style.bestStands.map(slug => {
                    const s = getStandBySlug(slug);
                    return s ? (
                      <a href={`/stands/${s.slug}`} class="text-xs font-bold text-white bg-primary/20 hover:bg-primary border border-primary/30 px-3 py-1.5 rounded-full transition-colors flex items-center gap-1">
                        {s.name}
                      </a>
                    ) : null;
                  })}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-16">
      <!-- Step-by-step section -->
      <section class="glass-panel p-8">
        <h2 class="text-2xl font-bold text-white mb-6">Step-by-Step: How to Get Bizarre Lineage Fighting Styles</h2>
        <p class="text-gray-300 mb-6 text-sm">Follow these exact instructions within the game map to secure your combat discipline without wasting time running around randomly.</p>
        
        <div class="space-y-4">
          <div class="flex gap-4 items-start">
            <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center font-bold text-white flex-shrink-0">1</div>
            <div>
              <strong class="text-white block mb-1">Gather In-Game Currency</strong>
              <p class="text-sm text-gray-400 m-0">All <strong class="text-gray-300">Bizarre Lineage Fighting Styles</strong> cost between $5,000 to $10,000. Defeat thugs or complete storyline quests to farm this cash quickly.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center font-bold text-white flex-shrink-0">2</div>
            <div>
              <strong class="text-white block mb-1">Locate the Specific Trainer NPC</strong>
              <p class="text-sm text-gray-400 m-0">Reference the exact bus stop locations mentioned in the cards above. The Boxing trainer is at the Gym, Kendo at the Dojo, and Vampirism hidden in the alleys at night.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center font-bold text-white flex-shrink-0">3</div>
            <div>
              <strong class="text-white block mb-1">Equip and Train</strong>
              <p class="text-sm text-gray-400 m-0">Once purchased, the new style is immediately bound to your character. Press your designated ability keys (usually B, N, M) to unleash your new moves in the wild.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- SEO FAQ Section -->
      <section class="glass-panel p-8">
        <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
          <HelpCircle className="text-accent" /> Bizarre Lineage Fighting Styles FAQ
        </h2>
        <div class="space-y-4">
          {faqs.map(faq => (
            <details class="bg-black/20 border border-white/5 rounded-xl overflow-hidden group">
              <summary class="font-bold text-white p-4 cursor-pointer hover:bg-white/5 transition-colors select-none list-none relative pr-10">
                {faq.question}
                <ChevronRight className="absolute right-4 top-4 text-gray-500 transition-transform group-open:rotate-90" size={20} />
              </summary>
              <p class="text-sm text-gray-400 px-4 pb-4 m-0 leading-relaxed border-t border-white/5 pt-3">
                {faq.answer}
              </p>
            </details>
          ))}
        </div>
      </section>
    </div>

    <!-- CTA Section -->
    <section class="mb-20 text-center animate-fade-in bg-[radial-gradient(ellipse_at_center,rgba(168,85,247,0.1)_0%,transparent_100%)] p-12 rounded-3xl border border-white/5">
      <h2 class="text-3xl font-black text-white mb-4">Ready to Dominate with Top Bizarre Lineage Fighting Styles?</h2>
      <p class="text-gray-300 max-w-2xl mx-auto mb-8 text-lg">
        Now that you understand the intricacies of every combat discipline, it's time to pair them with the ultimate Stand. Check out our comprehensive tier list to find the perfect synergistic match for your newly acquired skills.
      </p>
      <a href="/tier-list" class="inline-flex items-center gap-2 bg-white text-black font-black py-4 px-10 rounded-full hover:bg-gray-200 transition-all hover:scale-105 shadow-[0_0_20px_rgba(255,255,255,0.2)]">
        View Global Tier List <ArrowRight size={20} />
      </a>
    </section>

  </div>
</Layout>

<style>
  .glass-panel {
    background: var(--color-glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 20px;
  }
  
  /* Fallback icon for details polyfill if needed */
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
