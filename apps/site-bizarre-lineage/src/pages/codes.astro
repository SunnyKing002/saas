---
// src/pages/codes.astro
import Layout from "../layouts/Layout.astro";
import { activeCodes, expiredCodes, expectedRewards } from "../data/codes";
import { Gift, Copy, Check } from "lucide-react";
import FAQ from "../components/FAQ.astro";

const faqs = [
  {
    question: "What are the latest active Bizarre Lineage codes working right now?",
    answer: "Yes! There are currently several active Bizarre Lineage codes giving out free Stat Point Essences, Stand Stat Essences, and Rare Chests. You can find our fully verified list of codes above."
  },
  {
    question: "How do I redeem my Bizarre Lineage codes?",
    answer: "To redeem any Bizarre Lineage code, you must first join the Bizarre Collective Roblox group and Like the game on the main page. Then, load into the game, open the chat box in the top-left corner, and type '!code ' followed by your chosen code (e.g. '!code 100kLikes'). Press enter to claim the code's reward."
  },
  {
    question: "Where is the best place to find new Bizarre Lineage codes?",
    answer: "Right here! We constantly monitor the official Bizarre Lineage Discord server and the Trello board to ensure this list of codes is updated the very second a new code drops. Save this codes page!"
  },
  {
    question: "Do Bizarre Lineage codes expire?",
    answer: "Absolutely. Roblox game codes constantly expire after a few days or when a new major update drops. Bookmark our codes page to make sure you grab your Essences before these codes vanish."
  },
  {
    question: "Why isn't my Bizarre Lineage code working?",
    answer: "The most common reason a code fails is that you haven't joined the Roblox Group or Liked the game yet—this is a strict requirement for all codes. Alternatively, the code may have been typed without the '!code ' prefix, or the code has officially expired."
  }
];


---
<Layout
  title="Bizarre Lineage Codes (March 2026) – All Working Codes, Rewards"
  description="Bizarre Lineage codes updated for March 2026. Find every working code for Stat Point Essences, Rare Chests and more rewards, tested in game and refreshed daily."
  canonicalPath="/codes"
  exactTitle={true}
>


  <section class="section"><div class="container">
    <h1 class="section-title">All Bizarre Lineage Codes</h1>
    <p class="section-subtitle">Don't miss out on free <strong>Stat Point Essences</strong> and <strong>Rare Chests</strong> from the newest codes. We test and verify every single <b>Bizarre Lineage code</b> daily so you can maximize your rerolls without the hassle. Find all the latest active codes below and start dominating.</p>

    {activeCodes.length > 0 ? (
      <div class="codes-list">
        <h2 class="sub-title">Active Bizarre Lineage Codes</h2>
        {activeCodes.map((c) => (
          <div class={`code-card ${c.status}`}>
            <div class="code-action-group">
              <code class="code-text">{c.code}</code>
              <button class="copy-btn" onclick={`navigator.clipboard.writeText('${c.code}'); this.classList.add('copied'); setTimeout(() => this.classList.remove('copied'), 2000);`} aria-label="Copy code">
                <span class="icon-copy"><Copy size={16} /></span>
                <span class="icon-check"><Check size={16} /></span>
              </button>
            </div>
            <span class="code-reward">{c.reward}</span>
            <span class="code-status active">Active</span>
          </div>
        ))}
        <p class="text-sm text-gray-400 mt-4 mb-8"><em>* Remember: You MUST include the <code>!code</code> prefix exactly as shown above when claiming rewards in the chat box!</em></p>
      </div>
    ) : (
      <div class="no-codes glass-panel">
        <Gift size={48} className="no-codes-icon-svg" />
        <h2>No Active Bizarre Lineage Codes Yet</h2>
        <p>The Bizarre Lineage code redemption system hasn't been enabled by the devs yet. Bookmark this page — we will publish the absolute latest codes the second MIDAS hits the switch.</p>
      </div>
    )}

    <!-- How to Redeem -->
    <h2 class="sub-title">How to Redeem Bizarre Lineage Codes</h2>
    <div class="steps-grid">
      <div class="step-card glass-panel">
        <span class="step-num">1</span>
        <h3>Join the Community</h3>
        <p>Before doing anything, you <strong>must</strong> join the official 'Bizarre Collective' Roblox group and Like the game via the main page.</p>
      </div>
      <div class="step-card glass-panel">
        <span class="step-num">2</span>
        <h3>Launch the Game</h3>
        <p>Boot up Bizarre Lineage in Roblox and wait for your character to fully load into the server.</p>
      </div>
      <div class="step-card glass-panel">
        <span class="step-num">3</span>
        <h3>Open the Chat Box</h3>
        <p>Navigate to the top-left corner of your screen and click on the in-game text chat icon (or press '/').</p>
      </div>
      <div class="step-card glass-panel">
        <span class="step-num">4</span>
        <h3>Enter Final Code</h3>
        <p>Type the code exactly as written, including the <code>!code </code> prefix (e.g. <code>!code 100kLikes</code>), and hit Enter to claim!</p>
      </div>
    </div>

    <!-- Where Codes Come From -->
    <h2 class="sub-title">Where Do Bizarre Lineage Codes Come From?</h2>
    <div class="seo-block glass-panel">
      <p>If you're wondering who makes these codes, they are handed out directly by <b>MIDAS</b> and the official development team. The devs drop new codes to celebrate huge community milestones (like hitting massive Like goals on the Roblox page), whenever there's a big content patch, or even if servers slam and they need to hand out apology compensation.</p>
      <p>Want to hunt for them yourself? The two best official sources are the <a href="https://discord.com/invite/bizarrelineage" target="_blank" rel="noopener noreferrer" style="color:var(--color-primary);">Bizarre Lineage Discord Server</a> and the official <a href="https://trello.com/b/Zi6UTMnO/official-bizzare-lineage" target="_blank" rel="noopener noreferrer" style="color:var(--color-primary);">Trello board</a>. But honestly, watching Discord announcements all day is exhausting. Just bookmark our page instead — we do the heavy lifting for you.</p>
    </div>

    <!-- SEO Value Add & Milestones-->
    <h2 class="sub-title">Upcoming Bizarre Lineage Code Milestones</h2>
    <div class="seo-block glass-panel mb-8">
      <p>Developers usually drop a brand new <strong>Bizarre Lineage code</strong> whenever the game reaches a massive Like milestone on the official Roblox page. This means the community can actively work together to unlock the next code. Currently, the most anticipated code drop will occur at <strong>200,000 Likes</strong>. Once that milestone is hit, a huge new code will be released, likely rewarding premium items. We will update this codes list the absolute second the new codes drop.</p>
    </div>

    <h2 class="sub-title">What are Stat Point Essences in Bizarre Lineage?</h2>
    <div class="seo-block glass-panel mb-8">
      <p>As you can see from our active codes list, developers are primarily handing out <strong>Stat Point Essences</strong> and <strong>Stand Personality Essences</strong> via these codes right now rather than just plain cash. These rewards from codes are crucial high-tier items that dictate your entire build.</p>
      <p>A Stat Point Essence from a code allows you to respec and re-allocate points into Vitality, Strength, or specific Stand power scaling. Before using these highly coveted codes rewards, we highly recommend checking out our comprehensive <a href="/tier-list" style="color:var(--color-primary);">Stand Tier List</a>. Don't waste your precious Stat Essences maxing out scaling on a D-tier Stand! Make sure you have rolled something worthwhile like The World or Star Platinum before cashing these codes in.</p>
    </div>

    <!-- Expected Rewards -->
    <h2 class="sub-title">Types of Rewards from Codes</h2>
    <div class="rewards-grid">
      {expectedRewards.map((r) => (
        <div class="reward-card glass-panel">
          <span class="reward-icon">{r.icon}</span>
          <h3>{r.name}</h3>
          <p>{r.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="cta-box glass-panel">
      <h3>While You Wait for Bizarre Lineage Codes...</h3>
      <p>Make sure you are ready to use your rewards wisely. Check the tier list to know which Stand to keep, and browse our leveling guide to maximize your XP boosts.</p>
      <div class="cta-links">
        <a href="/tier-list" class="btn btn-primary">Bizarre Lineage Tier List</a>
        <a href="/stands" class="btn btn-outline">Browse All Stands</a>
        <a href="/guides/leveling" class="btn btn-outline">Leveling Guide</a>
      </div>
    </div>

    {expiredCodes.length > 0 && (
      <div class="expired-section">
        <h2 class="sub-title">Expired Bizarre Lineage Codes</h2>
        <p class="expired-note">These Bizarre Lineage codes no longer work. We keep them here for reference so you know which codes have already been released.</p>
        {expiredCodes.map((c) => (
          <div class="code-card expired">
            <code class="code-text">{c.code}</code>
            <span class="code-reward">{c.reward}</span>
            <span class="code-status expired">Expired</span>
          </div>
        ))}
      </div>
    )}

    <!-- FAQ -->
    <FAQ items={faqs} />
  </div></section>
</Layout>

<style>
  .sub-title { font-size: 1.3rem; font-weight: 700; color: var(--color-text-primary); margin: 2.5rem 0 1rem; }
  
  .glass-panel {
    background: var(--color-glass-bg); border: 1px solid var(--color-glass-border);
    border-radius: 16px; padding: 1.5rem;
  }
  
  .no-codes { text-align: center; padding: 3rem 2rem; margin: 2rem 0; }
  .no-codes-icon-svg { color: var(--color-accent); margin-bottom: 1rem; }
  .no-codes h2 { margin: 1rem 0 0.6rem; font-size: 1.3rem; color: var(--color-text-primary); }
  .no-codes p { margin: 0; color: var(--color-text-secondary); font-size: 0.95rem; max-width: 520px; margin: 0 auto; line-height: 1.6; }

  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem; }
  .step-card { text-align: center; padding: 1.5rem 1rem; }
  .step-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(139, 92, 246, 0.15); color: var(--color-primary);
    font-family: var(--font-heading); font-weight: 800; font-size: 1.1rem;
    margin-bottom: 0.8rem;
  }
  .step-card h3 { margin: 0 0 0.4rem; font-size: 1rem; color: var(--color-text-primary); }
  .step-card p { margin: 0; font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.5; }

  .seo-block { margin-bottom: 2rem; }
  .seo-block p { color: var(--color-text-secondary); line-height: 1.7; margin: 0 0 1rem; font-size: 0.95rem; }
  .seo-block p:last-child { margin-bottom: 0; }
  .seo-block strong { color: var(--color-text-primary); }

  .rewards-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .reward-card { text-align: center; }
  .reward-icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  .reward-card h3 { margin: 0 0 0.3rem; font-size: 0.95rem; color: var(--color-text-primary); }
  .reward-card p { margin: 0; font-size: 0.8rem; color: var(--color-text-secondary); line-height: 1.4; }

  .cta-box { text-align: center; margin-top: 2rem; background: linear-gradient(135deg, rgba(139,92,246,0.08), rgba(245,158,11,0.06)); border-color: rgba(139,92,246,0.15); }
  .cta-box h3 { margin: 0 0 0.4rem; font-size: 1.1rem; color: var(--color-text-primary); }
  .cta-box p { margin: 0 0 1.2rem; color: var(--color-text-secondary); font-size: 0.9rem; }
  .cta-links { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
  
  .btn { display: inline-flex; align-items: center; padding: 0.7rem 1.4rem; border-radius: 10px; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: all 0.2s; border: none; cursor: pointer; }
  .btn-primary { background: linear-gradient(135deg, #7c3aed, #a855f7); color: #fff; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(139,92,246,0.4); }
  .btn-outline { background: transparent; color: var(--color-primary); border: 1px solid rgba(139,92,246,0.3); }
  .btn-outline:hover { background: rgba(139,92,246,0.1); }

  .expired-note { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem; }
  .code-card { display: flex; align-items: center; gap: 1rem; padding: 0.8rem 1rem; background: var(--color-glass-bg); border: 1px solid var(--color-glass-border); border-radius: 10px; margin-bottom: 0.5rem; }
  .code-text { font-size: 1rem; font-weight: 700; color: #f59e0b; background: rgba(245,158,11,0.1); padding: 0.4rem 0.8rem; border-radius: 6px; }
  
  .code-action-group { display: flex; align-items: stretch; }
  .code-action-group .code-text { border-radius: 6px 0 0 6px; border-right: 1px solid rgba(245,158,11,0.2); }
  .copy-btn { margin: 0; background: rgba(245,158,11,0.1); border: none; padding: 0 0.7rem; border-radius: 0 6px 6px 0; color: #f59e0b; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
  .copy-btn:hover { background: rgba(245,158,11,0.25); color: #fff; }
  .copy-btn .icon-copy, .copy-btn .icon-check { display: flex; align-items: center; justify-content: center; }
  .copy-btn .icon-check { display: none; color: #10b981; }
  .copy-btn.copied { background: rgba(16, 185, 129, 0.15); border-color: rgba(16, 185, 129, 0.3); }
  .copy-btn.copied .icon-copy { display: none; }
  .copy-btn.copied .icon-check { display: flex; }

  .code-reward { font-size: 0.85rem; color: var(--color-text-secondary); flex: 1; }
  .code-status { font-size: 0.75rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 4px; }
  .code-card.active .code-status { background: rgba(34,197,94,0.15); color: #22c55e; }
  .code-card.upcoming .code-status { background: rgba(56,189,248,0.15); color: #38bdf8; }
  .code-card.expired .code-status { background: rgba(239,68,68,0.15); color: #ef4444; }
  .code-card.expired .code-text { color: #64748b; }
  
  .text-sm { font-size: 0.875rem; }
  .text-gray-400 { color: #9ca3af; }
  .mt-4 { margin-top: 1rem; }
  .mb-8 { margin-bottom: 2rem; }



  @media (max-width: 768px) { .rewards-grid, .steps-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .rewards-grid, .steps-grid { grid-template-columns: 1fr; } .cta-links { flex-direction: column; align-items: center; } }
</style>
