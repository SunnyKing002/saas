---
// apps/site-template/src/pages/blog/index.astro
// 博客列表页 - 从 CF Worker API 获取文章列表
import Layout from "../../layouts/Layout.astro";
import siteConfig from "../../../site.config";

// ----------------------------------------------------------------
// 数据获取策略：
// 静态构建时：通过 Worker API 在构建时拉取（build-time fetch）
// 运行时：由 Astro 生成静态页面，无需客户端请求
// ----------------------------------------------------------------

// TODO: 将 WORKER_API_URL 环境变量配置为 Worker 地址
const API_BASE = import.meta.env.WORKER_API_URL || "http://localhost:8787";

let posts: Array<{
  id: string;
  slug: string;
  title: string;
  summary: string;
  cover_url: string;
  published_at: string;
}> = [];

try {
  // 通过 Worker API 获取文章列表（构建时执行）
  const res = await fetch(`${API_BASE}/api/posts?site=${siteConfig.key}`);
  if (res.ok) {
    const data = await res.json() as { posts: typeof posts };
    posts = data.posts || [];
  }
} catch (e) {
  // 本地开发时 Worker 未启动，使用占位数据
  console.warn("[Blog] 无法连接 Worker API，使用占位数据");
  posts = [
    {
      id: "1",
      slug: "getting-started",
      title: "Getting Started with Our Platform",
      summary: "Learn how to set up your account and make your first API call in under 5 minutes.",
      cover_url: "",
      published_at: new Date().toISOString(),
    },
    {
      id: "2",
      slug: "best-practices",
      title: "10 Best Practices for SaaS Product Design",
      summary: "Discover the patterns and principles used by top SaaS companies to build products users love.",
      cover_url: "",
      published_at: new Date(Date.now() - 7 * 86400000).toISOString(),
    },
  ];
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<Layout
  seo={{
    title: `Blog — ${siteConfig.title}`,
    description: `Latest articles and guides from ${siteConfig.title}.`,
    canonicalUrl: `https://${siteConfig.domain}/blog`,
  }}
>
  <div class="container page-content">
    <header class="page-header">
      <h1>Blog</h1>
      <p>Insights, guides, and updates from the team.</p>
    </header>

    {posts.length === 0 ? (
      <div class="empty-state">
        <p>No posts yet. Check back soon!</p>
      </div>
    ) : (
      <div class="post-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-card">
            {post.cover_url && (
              <div class="post-cover">
                <img src={post.cover_url} alt={post.title} loading="lazy" />
              </div>
            )}
            <div class="post-body">
              <time class="post-date" datetime={post.published_at}>
                {formatDate(post.published_at)}
              </time>
              <h2 class="post-title">{post.title}</h2>
              <p class="post-summary">{post.summary}</p>
              <span class="read-more">Read more →</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  .page-content { padding: 4rem 1.5rem 6rem; }
  .page-header { margin-bottom: 3rem; }
  .page-header h1 { font-size: 2.5rem; font-weight: 800; color: #fff; margin: 0 0 0.75rem; }
  .page-header p { color: #64748b; font-size: 1.1rem; margin: 0; }
  .empty-state { text-align: center; padding: 4rem; color: #475569; }
  .post-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
  .post-card {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }
  .post-card:hover { border-color: rgba(99,102,241,0.3); transform: translateY(-3px); }
  .post-cover img { width: 100%; height: 200px; object-fit: cover; display: block; }
  .post-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .post-date { font-size: 0.8rem; color: #475569; text-transform: uppercase; letter-spacing: 0.06em; }
  .post-title { font-size: 1.15rem; font-weight: 700; color: #e2e8f0; margin: 0.5rem 0 0.75rem; line-height: 1.4; }
  .post-summary { font-size: 0.875rem; color: #64748b; margin: 0; flex: 1; line-height: 1.6; }
  .read-more { margin-top: 1rem; font-size: 0.85rem; color: #818cf8; font-weight: 600; }
</style>
