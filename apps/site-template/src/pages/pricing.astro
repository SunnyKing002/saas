---
// apps/site-template/src/pages/pricing.astro
// 定价页：订阅套餐 + 单次积分包
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pricing – Simple, Transparent Plans</title>
  <meta name="description" content="Choose the plan that fits your needs. Subscribe for monthly credits or buy one-time credit packs. Cancel anytime." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a0f;
      --surface: #13131a;
      --surface2: #1c1c28;
      --border: rgba(255,255,255,0.08);
      --accent: #7c3aed;
      --accent-light: #a78bfa;
      --accent-glow: rgba(124,58,237,0.25);
      --text: #f0f0f5;
      --muted: #9494a8;
      --green: #10b981;
    }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem; border-bottom: 1px solid var(--border);
      position: sticky; top: 0; background: rgba(10,10,15,0.8);
      backdrop-filter: blur(12px); z-index: 50;
    }
    .logo { font-size: 1.2rem; font-weight: 700; color: var(--text); text-decoration: none; }
    .logo span { color: var(--accent-light); }
    .hero {
      text-align: center; padding: 5rem 1rem 3rem;
      background: radial-gradient(ellipse at 50% -20%, rgba(124,58,237,0.15) 0%, transparent 70%);
    }
    .badge {
      display: inline-block; background: var(--accent-glow); border: 1px solid rgba(124,58,237,0.4);
      color: var(--accent-light); padding: 0.3rem 0.9rem; border-radius: 999px;
      font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; margin-bottom: 1rem; line-height: 1.1; }
    h1 .gradient { background: linear-gradient(135deg, #a78bfa, #34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .subtitle { font-size: 1.1rem; color: var(--muted); max-width: 540px; margin: 0 auto 3rem; }

    /* Toggle */
    .toggle-wrap { display: flex; justify-content: center; gap: 0.75rem; margin-bottom: 3.5rem; align-items: center; }
    .toggle-label { font-size: 0.9rem; color: var(--muted); }
    .toggle-label.active { color: var(--text); font-weight: 600; }
    .switch { position: relative; width: 48px; height: 28px; cursor: pointer; }
    .switch input { display: none; }
    .slider {
      position: absolute; inset: 0; background: var(--surface2); border: 1px solid var(--border);
      border-radius: 999px; transition: 0.3s;
    }
    .slider::before {
      content: ''; position: absolute; width: 20px; height: 20px; background: var(--accent-light);
      border-radius: 50%; top: 3px; left: 3px; transition: 0.3s;
    }
    input:checked + .slider { background: var(--accent); border-color: var(--accent); }
    input:checked + .slider::before { transform: translateX(20px); background: #fff; }
    .save-badge {
      font-size: 0.7rem; font-weight: 700; background: var(--green); color: #fff;
      padding: 0.15rem 0.5rem; border-radius: 999px;
    }

    /* Section titles */
    .section-title { text-align: center; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 2rem; }

    /* Cards grid */
    .cards { display: grid; gap: 1.5rem; padding: 0 1.5rem; max-width: 1100px; margin: 0 auto 5rem; }
    .cards-subscription { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
    .cards-credits { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); max-width: 800px; }

    .card {
      background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
      padding: 2rem; transition: transform 0.2s, box-shadow 0.2s; position: relative; overflow: hidden;
    }
    .card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
    .card.featured {
      border-color: rgba(124,58,237,0.5);
      background: linear-gradient(145deg, #16162a, #13131a);
      box-shadow: 0 0 0 1px rgba(124,58,237,0.3), 0 20px 60px rgba(124,58,237,0.1);
    }
    .card.featured::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at top, rgba(124,58,237,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .popular-badge {
      display: inline-block; background: linear-gradient(135deg, #7c3aed, #a78bfa);
      color: #fff; font-size: 0.7rem; font-weight: 700; padding: 0.25rem 0.75rem;
      border-radius: 999px; margin-bottom: 1rem; letter-spacing: 0.05em;
    }
    .card-icon { font-size: 2rem; margin-bottom: 0.75rem; }
    .card-name { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.25rem; }
    .card-desc { font-size: 0.85rem; color: var(--muted); margin-bottom: 1.5rem; }
    .price-row { display: flex; align-items: flex-end; gap: 0.25rem; margin-bottom: 0.5rem; }
    .price-amount { font-size: 2.5rem; font-weight: 800; line-height: 1; }
    .price-period { font-size: 0.875rem; color: var(--muted); padding-bottom: 0.25rem; }
    .credits-badge {
      display: inline-flex; align-items: center; gap: 0.35rem;
      background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.25);
      color: var(--green); padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.8rem; font-weight: 600;
      margin-bottom: 1.5rem;
    }
    .credits-badge svg { width: 14px; height: 14px; }
    .features { list-style: none; margin-bottom: 2rem; }
    .features li {
      display: flex; align-items: center; gap: 0.6rem;
      font-size: 0.875rem; color: var(--muted); padding: 0.4rem 0;
    }
    .features li::before { content: '✓'; color: var(--green); font-weight: 700; flex-shrink: 0; }
    .btn-primary {
      display: block; width: 100%; padding: 0.875rem; border-radius: 12px; border: none;
      background: linear-gradient(135deg, #7c3aed, #a78bfa); color: #fff;
      font-size: 0.95rem; font-weight: 600; cursor: pointer; text-align: center;
      transition: opacity 0.2s, transform 0.1s; text-decoration: none;
    }
    .btn-primary:hover { opacity: 0.9; transform: scale(1.01); }
    .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-secondary {
      display: block; width: 100%; padding: 0.875rem; border-radius: 12px;
      border: 1px solid var(--border); background: transparent; color: var(--text);
      font-size: 0.95rem; font-weight: 600; cursor: pointer; text-align: center;
      transition: border-color 0.2s, background 0.2s; text-decoration: none;
    }
    .btn-secondary:hover { border-color: var(--accent-light); background: var(--accent-glow); }

    /* FAQ */
    .faq-section { max-width: 680px; margin: 0 auto 5rem; padding: 0 1.5rem; }
    .faq-section h2 { text-align: center; font-size: 1.75rem; font-weight: 700; margin-bottom: 2rem; }
    .faq-item { border-bottom: 1px solid var(--border); padding: 1.25rem 0; }
    .faq-q { font-size: 0.95rem; font-weight: 600; cursor: pointer; display: flex; justify-content: space-between;
      align-items: center; user-select: none; }
    .faq-q::after { content: '+'; font-size: 1.2rem; color: var(--muted); flex-shrink: 0; }
    .faq-a { font-size: 0.875rem; color: var(--muted); margin-top: 0.75rem; line-height: 1.7;
      display: none; }
    .faq-item.open .faq-a { display: block; }
    .faq-item.open .faq-q::after { content: '−'; }

    .toast { position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%) translateY(100px);
      background: var(--surface2); border: 1px solid var(--border); color: var(--text);
      padding: 0.75rem 1.5rem; border-radius: 12px; font-size: 0.875rem; font-weight: 600;
      transition: transform 0.3s; z-index: 100; }
    .toast.show { transform: translateX(-50%) translateY(0); }
    .toast.error { border-color: #ef4444; color: #fca5a5; }

    footer { text-align: center; padding: 2rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.8rem; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="logo">Saas<span>Matrix</span></a>
    <a href="/dashboard" style="font-size:0.875rem;color:var(--muted);text-decoration:none;">Dashboard →</a>
  </nav>

  <section class="hero">
    <div class="badge">⚡ Pricing</div>
    <h1>Simple, <span class="gradient">transparent</span> pricing</h1>
    <p class="subtitle">Subscribe for monthly credit pools or top up with one-time packs. Pay as you grow, cancel anytime.</p>

    <div class="toggle-wrap">
      <span class="toggle-label active" id="monthly-label">Monthly</span>
      <label class="switch">
        <input type="checkbox" id="billing-toggle">
        <span class="slider"></span>
      </label>
      <span class="toggle-label" id="yearly-label">Yearly <span class="save-badge">Save 20%</span></span>
    </div>
  </section>

  <!-- Subscription Plans -->
  <p class="section-title">Subscription Plans</p>
  <div class="cards cards-subscription" id="subscription-cards">
    <div class="card" data-plan-id="" data-billing="monthly">
      <div class="card-icon">🚀</div>
      <div class="card-name">Starter</div>
      <div class="card-desc">Perfect for individuals getting started</div>
      <div class="price-row">
        <span class="price-amount" data-monthly="$9.9" data-yearly="$7.9">$9.9</span>
        <span class="price-period">/month</span>
      </div>
      <span class="credits-badge">
        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 14.5a6.5 6.5 0 110-13 6.5 6.5 0 010 13zm.75-9.25a.75.75 0 00-1.5 0v3.25H7.5a.75.75 0 000 1.5h2.5a.75.75 0 00.75-.75v-4z"/></svg>
        500 credits / month
      </span>
      <ul class="features">
        <li>500 AI credits per month</li>
        <li>Email support</li>
        <li>API access</li>
        <li>Cancel anytime</li>
      </ul>
      <button class="btn-secondary" onclick="startCheckout(this)" data-plan-name="Starter">Get Starter</button>
    </div>

    <div class="card featured" data-plan-id="" data-billing="monthly">
      <span class="popular-badge">⭐ Most Popular</span>
      <div class="card-icon">🔥</div>
      <div class="card-name">Pro</div>
      <div class="card-desc">For power users and growing teams</div>
      <div class="price-row">
        <span class="price-amount" data-monthly="$29.9" data-yearly="$23.9">$29.9</span>
        <span class="price-period">/month</span>
      </div>
      <span class="credits-badge">
        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 14.5a6.5 6.5 0 110-13 6.5 6.5 0 010 13zm.75-9.25a.75.75 0 00-1.5 0v3.25H7.5a.75.75 0 000 1.5h2.5a.75.75 0 00.75-.75v-4z"/></svg>
        2,000 credits / month
      </span>
      <ul class="features">
        <li>2,000 AI credits per month</li>
        <li>Priority support</li>
        <li>Full API access</li>
        <li>Advanced analytics</li>
        <li>Cancel anytime</li>
      </ul>
      <button class="btn-primary" onclick="startCheckout(this)" data-plan-name="Pro">Get Pro</button>
    </div>
  </div>

  <!-- Credit Packs -->
  <p class="section-title" style="margin-top:1rem;">One-Time Credit Packs</p>
  <div class="cards cards-credits" style="margin:0 auto 5rem;">
    <div class="card" data-plan-id="">
      <div class="card-icon">💧</div>
      <div class="card-name">100 Credits</div>
      <div class="card-desc">Just getting started</div>
      <div class="price-row"><span class="price-amount">$1.9</span></div>
      <span class="credits-badge">100 credits · never expire</span>
      <ul class="features"><li>Instant delivery</li><li>No subscription</li></ul>
      <button class="btn-secondary" onclick="startCheckout(this)" data-plan-name="Credits 100">Buy $1.9</button>
    </div>
    <div class="card featured" data-plan-id="">
      <span class="popular-badge">Best Value</span>
      <div class="card-icon">💎</div>
      <div class="card-name">500 Credits</div>
      <div class="card-desc">Great for regular users</div>
      <div class="price-row"><span class="price-amount">$7.9</span></div>
      <span class="credits-badge">500 credits · never expire</span>
      <ul class="features"><li>Instant delivery</li><li>No subscription</li><li>Best per-credit price</li></ul>
      <button class="btn-primary" onclick="startCheckout(this)" data-plan-name="Credits 500">Buy $7.9</button>
    </div>
    <div class="card" data-plan-id="">
      <div class="card-icon">⚡</div>
      <div class="card-name">Lifetime</div>
      <div class="card-desc">Maximum power, one payment</div>
      <div class="price-row"><span class="price-amount">$199</span></div>
      <span class="credits-badge">10,000 credits · never expire</span>
      <ul class="features"><li>Instant delivery</li><li>No subscription</li><li>Maximum savings</li></ul>
      <button class="btn-secondary" onclick="startCheckout(this)" data-plan-name="Lifetime">Buy $199</button>
    </div>
  </div>

  <!-- FAQ -->
  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-item">
      <div class="faq-q">What are credits?</div>
      <div class="faq-a">Credits are the currency for using AI features in the app. Each action (generation, analysis, etc.) consumes a certain number of credits. Credits purchased in packs never expire.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">Can I cancel my subscription?</div>
      <div class="faq-a">Yes, you can cancel anytime from your billing portal. You'll keep access until the end of the billing period.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">Do subscription credits roll over?</div>
      <div class="faq-a">Monthly subscription credits reset each billing cycle. However, any credits you purchase separately (one-time packs) never expire and stack with your subscription credits.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">What payment methods do you accept?</div>
      <div class="faq-a">We accept all major credit and debit cards (Visa, Mastercard, American Express) via our secure payment partner Creem.</div>
    </div>
  </section>

  <footer>© 2025 SaasMatrix · <a href="/privacy" style="color:inherit">Privacy</a> · <a href="/terms" style="color:inherit">Terms</a></footer>

  <div class="toast" id="toast"></div>

  <script>
    // Load plans from API
    async function loadPlans() {
      try {
        const res = await fetch('/api/plans');
        if (!res.ok) return;
        const { subscriptionPlans, creditPackages } = await res.json();

        // Match subscription plans to cards
        const subCards = document.querySelectorAll('.cards-subscription .card');
        const planNames = ['Starter', 'Pro'];
        planNames.forEach((name, i) => {
          const plan = subscriptionPlans.find(p => p.name === name);
          if (plan && subCards[i]) {
            subCards[i].dataset.planId = plan.id;
            if (name === 'Pro') {
              subCards[i].dataset.monthlyPlanId = plan.id;
              const yearlyPlan = subscriptionPlans.find(p => p.name === 'Pro Yearly');
              if (yearlyPlan) {
                subCards[i].dataset.yearlyPlanId = yearlyPlan.id;
              }
            }
          }
        });

        // Match credit packages
        const creditCards = document.querySelectorAll('.cards-credits .card');
        const creditNames = ['Credits 100', 'Credits 500', 'Lifetime'];
        creditNames.forEach((name, i) => {
          const plan = creditPackages.find(p => p.name === name);
          if (plan && creditCards[i]) creditCards[i].dataset.planId = plan.id;
        });
      } catch (e) {
        console.error('Failed to load plans:', e);
      }
    }

    // Billing toggle
    const toggle = document.getElementById('billing-toggle');
    const monthlyLabel = document.getElementById('monthly-label');
    const yearlyLabel = document.getElementById('yearly-label');
    toggle.addEventListener('change', () => {
      const isYearly = toggle.checked;
      monthlyLabel.classList.toggle('active', !isYearly);
      yearlyLabel.classList.toggle('active', isYearly);

      document.querySelectorAll('[data-monthly]').forEach(el => {
        el.textContent = isYearly ? el.dataset.yearly : el.dataset.monthly;
      });
      document.querySelectorAll('[data-billing]').forEach(card => {
        card.dataset.billing = isYearly ? 'yearly' : 'monthly';
      });

      // Update Pro card planId if yearly plan exists
      const proCard = document.querySelector('.card .btn-primary[data-plan-name="Pro"]')?.closest('.card');
      if (proCard && proCard.dataset.yearlyPlanId) {
        proCard.dataset.planId = isYearly ? proCard.dataset.yearlyPlanId : proCard.dataset.monthlyPlanId;
      }
    });

    // Checkout
    async function startCheckout(btn) {
      const card = btn.closest('.card');
      const planId = card.dataset.planId;

      if (!planId) {
        showToast('Plan not configured yet. Please contact support.', true);
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Loading...';

      try {
        // Check login first
        const authRes = await fetch('/api/auth/me');
        const { user } = await authRes.json();
        if (!user) {
          window.location.href = '/auth/login?redirect=/pricing';
          return;
        }

        const res = await fetch('/api/payment/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ planId }),
        });

        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || 'Checkout failed');
        }

        const { checkoutUrl } = await res.json();
        window.location.href = checkoutUrl;
      } catch (err) {
        showToast(err.message || 'Something went wrong', true);
        btn.disabled = false;
        btn.textContent = btn.dataset.planName ? `Buy ${btn.dataset.planName}` : 'Try again';
      }
    }

    function showToast(msg, isError = false) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.className = 'toast show' + (isError ? ' error' : '');
      setTimeout(() => toast.className = 'toast', 4000);
    }

    // FAQ toggles
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => q.parentElement.classList.toggle('open'));
    });

    loadPlans();
  </script>
</body>
</html>
