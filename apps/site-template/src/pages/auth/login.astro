---
// apps/site-template/src/pages/auth/login.astro
// Google OAuth 登录页面
import Layout from "../../layouts/Layout.astro";
import siteConfig from "../../../site.config";

const WORKER_API_URL = import.meta.env.WORKER_API_URL || "http://localhost:8787";
const loginUrl = `${WORKER_API_URL}/api/auth/google`;

// SEO
const seo = {
  title: `Sign In · ${siteConfig.title}`,
  description: "Sign in to your account with Google to access all features.",
  noindex: true,
};
---

<Layout seo={seo}>
  <div class="auth-page">
    <!-- Background animated gradient -->
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>
    <div class="bg-orb bg-orb-3"></div>

    <div class="auth-card" role="main">
      <!-- Logo / Brand -->
      <div class="brand">
        <div class="brand-icon" aria-hidden="true">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
            <defs>
              <linearGradient id="logo-grad" x1="0" y1="0" x2="36" y2="36" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#818cf8"/>
                <stop offset="100%" stop-color="#c084fc"/>
              </linearGradient>
            </defs>
            <rect width="36" height="36" rx="10" fill="url(#logo-grad)"/>
            <path d="M10 18h16M18 10v16" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="brand-name">{siteConfig.title}</span>
      </div>

      <!-- Heading -->
      <h1 class="auth-title">Welcome back</h1>
      <p class="auth-subtitle">Sign in to continue to {siteConfig.title}</p>

      <!-- Error message (from redirect params) -->
      <div class="error-banner" id="errorBanner" role="alert" style="display:none"></div>

      <!-- Google Sign In Button -->
      <a
        href={loginUrl}
        class="google-btn"
        id="googleSignInBtn"
        aria-label="Continue with Google"
      >
        <svg class="google-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <span>Continue with Google</span>
      </a>

      <!-- Divider -->
      <div class="divider" aria-hidden="true">
        <span>Secure sign in</span>
      </div>

      <!-- Trust badges -->
      <div class="trust-badges">
        <div class="badge">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1L2 3.5V8c0 3.3 2.5 5.8 6 7 3.5-1.2 6-3.7 6-7V3.5L8 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
          </svg>
          <span>Secure & Private</span>
        </div>
        <div class="badge">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.2"/>
            <path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>No password needed</span>
        </div>
        <div class="badge">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="2" y="7" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
            <path d="M5 7V5a3 3 0 016 0v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <span>HTTP-only cookies</span>
        </div>
      </div>

      <!-- Terms -->
      <p class="terms">
        By signing in, you agree to our
        <a href="/terms">Terms of Service</a> and
        <a href="/privacy">Privacy Policy</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  // Show error from URL param
  const params = new URLSearchParams(window.location.search);
  const error = params.get("error");
  if (error) {
    const errorMap: Record<string, string> = {
      state_mismatch: "Security check failed. Please try again.",
      invalid_request: "Invalid request. Please try again.",
      access_denied: "Access was denied. Please try signing in again.",
      site_not_found: "Site configuration error. Please contact support.",
    };
    const banner = document.getElementById("errorBanner");
    if (banner) {
      banner.textContent = errorMap[error] || `Sign in failed: ${error}`;
      banner.style.display = "block";
    }
  }

  // Add loading state to button
  const btn = document.getElementById("googleSignInBtn");
  btn?.addEventListener("click", () => {
    btn.classList.add("loading");
    btn.setAttribute("aria-busy", "true");
  });
</script>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    position: relative;
    overflow: hidden;
  }

  /* Animated background orbs */
  .bg-orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
    animation: float 8s ease-in-out infinite;
  }
  .bg-orb-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(129,140,248,0.15) 0%, transparent 70%);
    top: -150px; left: -100px;
    animation-delay: 0s;
  }
  .bg-orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(192,132,252,0.12) 0%, transparent 70%);
    bottom: -100px; right: -80px;
    animation-delay: 3s;
  }
  .bg-orb-3 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(99,102,241,0.1) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: 6s;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }

  /* Auth Card */
  .auth-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 420px;
    background: rgba(15, 15, 25, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    backdrop-filter: blur(20px);
    box-shadow:
      0 0 0 1px rgba(129, 140, 248, 0.05),
      0 25px 50px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    animation: slideUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Brand */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .brand-icon { display: flex; }
  .brand-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: #e2e8f0;
    letter-spacing: -0.02em;
  }

  /* Headings */
  .auth-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: #f1f5f9;
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }
  .auth-subtitle {
    font-size: 0.95rem;
    color: #64748b;
    margin: 0 0 2rem;
  }

  /* Error banner */
  .error-banner {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #fca5a5;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  /* Google Button */
  .google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    width: 100%;
    padding: 0.875rem 1.5rem;
    min-height: 52px;
    background: rgba(255, 255, 255, 0.97);
    color: #1a1a2e;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255,255,255,0.1);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    letter-spacing: 0.01em;
  }
  .google-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.15) 100%);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .google-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255,255,255,0.2);
    background: #ffffff;
  }
  .google-btn:hover::before { opacity: 1; }
  .google-btn:active { transform: translateY(0); }
  .google-btn.loading {
    opacity: 0.7;
    pointer-events: none;
  }
  .google-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .divider::before, .divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
  }
  .divider span {
    font-size: 0.75rem;
    color: #475569;
    white-space: nowrap;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Trust badges */
  .trust-badges {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .badge {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8rem;
    color: #475569;
  }
  .badge svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: #4ade80;
  }

  /* Terms */
  .terms {
    margin: 1.5rem 0 0;
    font-size: 0.75rem;
    color: #334155;
    text-align: center;
    line-height: 1.6;
  }
  .terms a {
    color: #6366f1;
    text-decoration: none;
  }
  .terms a:hover { text-decoration: underline; }

  @media (max-width: 480px) {
    .auth-card { padding: 2rem 1.25rem; }
    .auth-title { font-size: 1.5rem; }
  }
</style>
