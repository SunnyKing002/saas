# apps/site-template/.env.example
# 将此文件复制为 .env 并填写实际值

# 当前站点 key（与 D1 sites.key 对应）
SITE_KEY=site-template

# 站点完整 URL（用于 Astro sitemap 和 canonical URL）
SITE_DOMAIN=https://yourtool.example.com

# Cloudflare Worker API 地址（构建时 Astro 调用此地址获取动态数据）
# 本地开发：http://localhost:8787
# 生产环境：https://site-template-worker.youraccount.workers.dev
WORKER_API_URL=http://localhost:8787
